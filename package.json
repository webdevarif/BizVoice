{
  "name": "bizvoice",
  "version": "0.1.25",
  "description": "AI voice typing for Windows — Whisper + GPT powered, works in any app",
  "main": "dist-electron/main/index.js",
  "author": "BizVoice",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm version patch --no-git-tag-version && vite build && electron-builder && node scripts/publish-to-bizgrowhub.mjs",
    "release": "node scripts/release.mjs",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@fugood/whisper.node": "^1.0.19",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@ricky0123/vad-web": "^0.0.30",
    "audiobuffer-to-wav": "^1.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "extendable-media-recorder": "^9.2.37",
    "extendable-media-recorder-wav-encoder": "^7.0.137",
    "lenis": "^1.3.23",
    "onnxruntime-web": "^1.24.3",
    "openai": "^4.67.3",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@types/audiobuffer-to-wav": "^1.0.4",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.bizvoice.app",
    "productName": "BizVoice",
    "asar": true,
    "asarUnpack": [
      "dist/vad/**"
    ],
    "directories": {
      "output": "release/${version}"
    },
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "!dist/vad/ort-wasm-simd-threaded.asyncify.wasm",
      "!dist/vad/ort-wasm-simd-threaded.asyncify.mjs",
      "!node_modules/onnxruntime-web/**",
      "!node_modules/@hugeicons/**",
      "!node_modules/@fugood/node-whisper-win32-x64-cuda/**",
      "!node_modules/@fugood/node-whisper-win32-x64-vulkan/**",
      "!node_modules/@ricky0123/vad-web/**",
      "!node_modules/standardized-audio-context/**",
      "!node_modules/extendable-media-recorder/**",
      "!node_modules/extendable-media-recorder-wav-encoder/**",
      "!node_modules/audiobuffer-to-wav/**",
      "!node_modules/lenis/**",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BizVoice"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "webdevarif",
        "repo": "BizVoice",
        "releaseType": "release"
      }
    ]
  }
}
